---
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'

import '@fontsource-variable/eb-garamond'
import '@fontsource/lato'

interface Props {
	title: string;
	description: string;
	keywords: string;
	image?: string;
	path?: string;
	footer?: boolean;
	header?: boolean;
}

const { title, description, image, keywords, footer=false, header=false } = Astro.props;
const {
	href, 
	pathname
} = Astro.url
const { PUBLIC_SITE_URL } = import.meta.env
const url = PUBLIC_SITE_URL + (pathname.startsWith('/') ? pathname : '/' + pathname)


---

<!doctype html>
<html lang="es" class="dark">
	<head>
		<meta charset="UTF-8" />
		<meta http-equiv="Content-Type" content="text/html; charset=UTF-8">
		<meta name="viewport" content="width=device-width" />
		<meta name="keywords" content={keywords} />
		<meta name="description" content={description} />

    	<!-- Favicon -->
		<link rel="icon" type="image/webp" href="/img/escudo.webp">
		<link rel="alternate icon" type="image/png" href="/img/escudo.png">
		
    	<!-- Author -->
		<meta name="author" content="Fenrig Dev" />

    	<!-- Open Graph (Facebook, LinkedIn, etc.) -->
		<meta property="og:url" content={url}>
		<meta property="og:type" content="website">
		<meta property="og:title" content={title}>
		<meta property="og:description" content={description}>
		<meta property="og:image" content={image}>
		
		<!-- Twitter Card -->
		<meta name="twitter:card" content="summary_large_image">
		<meta property="twitter:url" content={url}>
		<meta name="twitter:title" content={title}>
		<meta name="twitter:description" content={description}>
		<meta name="twitter:image" content={image}>

		<meta name="robots" content="index, follow">

		<title>{title}</title>

		<link
      		rel="preload"
			href="/fonts/roman_sd.ttf"
			as="font"
			type="font/ttf"
			crossorigin
		/>
	</head>
	<body class="bg-brand-pearl text-brand-black dark:bg-brand-black dark:text-brand-pearl">
		{header && <Header />}
		<slot />
		{footer && <Footer />}
	</body>
</html>

<style is:global>
	:root {
		color-scheme: light;
		--scrollbar-thumb: rgba(0, 0, 0, 0.3);
		--scrollbar-track: rgba(0, 0, 0, 0.08);
	}
	:root.dark {
		color-scheme: dark;
		--scrollbar-thumb: rgba(255, 255, 255, 0.3);
		--scrollbar-track: rgba(255, 255, 255, 0.12);
	}
	@font-face {
		font-family: 'Roman SD';
		src: url('/fonts/roman_sd.ttf') format('truetype');
		font-weight: 400;
		font-style: normal;
	}
	html {
		font-family: 'Lato', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
	}
	body {
		margin: 0;
		padding: 0;
		box-sizing: border-box;
		width: 100vw;
		/* height: 100vh; */
		/* overflow: hidden; */
		overflow-x: hidden;
		/* height: 1500px; */
		display: ;
	}
	
      
	::-webkit-scrollbar {
        width: 8px;
		background: transparent;
	}
	::-webkit-scrollbar-track {
		margin-top: 100px;
		background: var(--scrollbar-track);
		backdrop-filter: blur(10px);
		border-radius: 5px;

	}
	::-webkit-scrollbar-thumb {
		background: var(--scrollbar-thumb);
		backdrop-filter: blur(10px);
		border-radius: 5px;
	}
	::-webkit-scrollbar-thumb:hover {
		background: color-mix(in srgb, var(--scrollbar-thumb) 70%, transparent);
	}

</style>
