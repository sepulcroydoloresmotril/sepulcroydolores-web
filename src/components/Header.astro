---
import Logo from "./Logo.astro";
---

<header id="header-nav" class="fixed top-0 w-full px-6 py-6 md:py-1 z-50 h-[100px]">
	<div class="max-w-7xl mx-auto flex items-center gap-4">
		<div class="flex items-center justify-start gap-1 sm:gap-1">
			<Logo class="logo-dark hidden w-16 h-16 sm:w-24 sm:h-auto" isDark />
			<Logo class="logo-light w-16 h-16 sm:w-24 sm:h-auto" />
			<span
				class="container w-[40ch] font-garamond uppercase text-lg text-brand-black dark:text-brand-pearl leading-1"
				>Cofradía del Santo Sepulcro y Nuestra Señora de los Dolores</span
			>
		</div>

		<button
			id="theme-toggle"
			type="button"
			class="ml-auto rounded-full border border-brand-black/30 px-4 py-2 text-sm uppercase tracking-wide text-brand-black hover:border-brand-black/60 dark:border-brand-pearl/40 dark:text-brand-pearl dark:hover:border-brand-pearl/70"
			aria-pressed="false"
		>
			Dark
		</button>
	</div>
</header>

<style>
	#header-nav {
		animation: blur linear both;
		animation-timeline: scroll();
		animation-range: 0 300px;
	}

	@keyframes blur {
		to {
			box-shadow:
				0px 5px 50px -5px rgba(0, 0, 0, 0.1),
				0px 0px 0 1px rgba(0, 0, 0, 0.2);
			background: rgba(244, 242, 239, 0.75);
			backdrop-filter: blur(10px);
		}
	}

	:global(html.dark) #header-nav {
		animation: blur-dark linear both;
	}

	@keyframes blur-dark {
		to {
			box-shadow:
				0px 5px 50px -5px rgba(0, 0, 0, 0.15),
				0px 0px 0 1px rgba(255, 255, 255, 0.15);
			background: rgba(25, 25, 25, 0.6);
			backdrop-filter: blur(10px);
		}
	}

	:global(html.dark) .logo-dark {
		display: block;
	}

	:global(html.dark) .logo-light {
		display: none;
	}
</style>

<script is:inline>
	const storageKey = "theme";
	const root = document.documentElement;
	const button = document.getElementById("theme-toggle");

	const applyTheme = (theme) => {
		root.classList.toggle("dark", theme === "dark");
		localStorage.setItem(storageKey, theme);
		if (button) {
			const isDark = theme === "dark";
			button.setAttribute("aria-pressed", String(isDark));
			button.textContent = isDark ? "Light" : "Dark";
		}
	};

	const stored = localStorage.getItem(storageKey);
	applyTheme(stored || "dark");

	if (button) {
		button.addEventListener("click", () => {
			const next = root.classList.contains("dark") ? "light" : "dark";
			applyTheme(next);
		});
	}
</script>
