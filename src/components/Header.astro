---
import Logo from "./Logo.astro";
---

<header id="header-nav" class="fixed top-0 w-full px-6 py-4 z-50 h-nav">
	<div class="max-w-7xl mx-auto flex items-center justify-start ">
		
		<picture>
			<source srcset="/img/logos/brand/dark/escudo_color_dark.png" type="image/webp" />
			<img
				class={`max-w-full aspect-square h-24 -mt-3 `}
				srcset="/img/escudo.webp"
				src="/img/escudo.png"
				alt="Ciclo de Conferencias - Cofradía del Santo Sepulcro y Ntra. Sra. de los Dolores (Motril)"
			/>
		</picture>
		<span class="-mt-3 container font-garamond uppercase uppercase w-[40ch] sm:text-lg text-lg  text-theme-white sm:leading-tight">
			Cofradía del Santo Sepulcro y Nuestra Señora de los Dolores</span
		>
	</div>
</header>

<style>
	#header-nav {
		animation: blur linear both;
		animation-timeline: scroll();
		animation-range: 0 300px;
	}

	@keyframes blur {
		to {
			box-shadow:
				0px 5px 50px -5px rgba(0, 0, 0, 0.1),
				0px 0px 0 1px rgba(0, 0, 0, 0.3);
			background: rgba(0, 0, 0, 0.3);
			backdrop-filter: blur(10px);
		}
	}
</style>
