---
import Logo from "./Logo.astro";
const {spacetop = false} = Astro.props
---

<header id="header-nav" class="fixed top-0 w-full px-6 py-3 z-50 h-fit">
	<div class="max-w-7xl mx-auto flex items-center gap-4">
		<a href="/" class="flex items-center justify-start gap-3">
			<Logo class="logo-dark hidden w-12 h-12 sm:w-16 sm:h-16 object-cover flex-shrink-0" isDark />
			<Logo class="logo-light w-12 h-12 sm:w-16 sm:h-16 object-cover flex-shrink-0" />
			<span class="font-garamond uppercase text-[0.7rem] sm:text-sm leading-snug text-brand-black dark:text-brand-pearl max-w-[24ch] sm:max-w-[32ch]">
				Cofradía del Santo Sepulcro<br class="hidden sm:block" /> y Nuestra Señora de los Dolores
			</span>
		</a>

		<button
			id="theme-toggle"
			type="button"
			class="ml-auto rounded-sm border border-brand-black/25 px-3 py-1.5 text-xs uppercase tracking-widest text-brand-black/70 hover:border-brand-red hover:text-brand-red dark:border-brand-pearl/30 dark:text-brand-pearl/70 dark:hover:border-brand-red dark:hover:text-brand-red transition-colors duration-200"
			aria-pressed="false"
		>
			Dark
		</button>
	</div>
</header>
{spacetop ? <div class="mt-[80px]"/> : null}

<style>
	#header-nav {
		animation: blur linear both;
		animation-timeline: scroll();
		animation-range: 0 300px;
	}

	@keyframes blur {
		to {
			box-shadow:
				0px 1px 0px 0px rgba(0, 0, 0, 0.08),
				0px 4px 24px -4px rgba(0, 0, 0, 0.06);
			background: rgba(244, 242, 239, 0.88);
			backdrop-filter: blur(12px);
		}
	}

	:global(html.dark) #header-nav {
		animation: blur-dark linear both;
		animation-timeline: scroll();
		animation-range: 0 300px;
	}

	@keyframes blur-dark {
		to {
			box-shadow:
				0px 1px 0px 0px rgba(255, 255, 255, 0.06),
				0px 4px 24px -4px rgba(0, 0, 0, 0.3);
			background: rgba(25, 25, 25, 0.85);
			backdrop-filter: blur(12px);
		}
	}

	:global(html.dark) .logo-dark {
		display: block;
	}

	:global(html.dark) .logo-light {
		display: none;
	}
</style>

<script is:inline>
	const storageKey = "theme";
	const root = document.documentElement;
	const button = document.getElementById("theme-toggle");

	const applyTheme = (theme) => {
		root.classList.toggle("dark", theme === "dark");
		localStorage.setItem(storageKey, theme);
		if (button) {
			const isDark = theme === "dark";
			button.setAttribute("aria-pressed", String(isDark));
			button.textContent = isDark ? "Light" : "Dark";
		}
	};

	const stored = localStorage.getItem(storageKey);
	applyTheme(stored || "dark");

	if (button) {
		button.addEventListener("click", () => {
			const next = root.classList.contains("dark") ? "light" : "dark";
			applyTheme(next);
		});
	}
</script>
