---
const {img, name, title, description} = Astro.props
---

<article class="group relative flex flex-col items-center w-full overflow-hidden border border-brand-black/10 dark:border-brand-pearl/10 hover:border-brand-gold/50 dark:hover:border-brand-gold/35 transition-all duration-400 bg-brand-pearl dark:bg-brand-black hover:shadow-lg">

	<!-- Top gold accent line -->
	<div class="w-full h-px bg-gradient-to-r from-transparent via-brand-gold/50 to-transparent"></div>

	<div class="w-full px-8 py-10 flex flex-col items-center text-center">

		<!-- Photo with gold ring -->
		<figure class="relative mb-5">
			<div class="absolute -inset-1 rounded-full bg-gradient-to-b from-brand-gold/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
			<picture>
				<source srcset={`/img/speakers/${img}.webp`} type="image/webp" />
				<img
					class="relative object-cover object-top w-32 h-32 rounded-full border border-brand-gold/30 group-hover:border-brand-gold/70 transition-colors duration-400"
					src={`/img/speakers/${img}.jpg`}
					alt={`Ponente: ${name}`}
				/>
			</picture>
		</figure>

		<!-- Name -->
		<h3 class="text-xl font-bold text-brand-black dark:text-brand-pearl font-garamond leading-tight">
			{name}
		</h3>

		<!-- Role -->
		<h4 class="text-sm text-brand-gold italic mt-1 tracking-wide">{title}</h4>

		<!-- Thin gold divider -->
		<div class="w-8 h-px bg-brand-gold/50 my-5"></div>

		<!-- Bio -->
		{description.map((paragraph: string) => (
			<p class="text-base text-left text-brand-black/68 dark:text-brand-pearl/75 leading-7 [text-wrap:pretty] mt-3 first:mt-0">
				{paragraph}
			</p>
		))}
	</div>

	<!-- Bottom hover accent -->
	<div class="w-full h-px bg-gradient-to-r from-transparent via-brand-red/30 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-400"></div>
</article>
