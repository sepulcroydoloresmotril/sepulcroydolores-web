---
const { class: astro_class = '', isDark = false } = Astro.props
const imgName = isDark ? '/img/escudo_dark' : '/img/escudo_light'
---

<picture>
    <source srcset={imgName + '.webp'} type="image/webp" />
    <img
        {...Astro.props}
        class={`max-w-full aspect-square ${astro_class}`}
        srcset={imgName + '.webp'}
        src={imgName + '.png'}
        alt="Ciclo de Conferencias - Cofradía del Santo Sepulcro y Ntra. Sra. de los Dolores (Motril)"
    />
</picture>