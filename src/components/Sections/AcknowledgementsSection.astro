---
import SectionTitle from "../SectionTitle.astro";

const PUBLIC_MOTRIL_CULTURA_URL = "http://www.motril.es/index.php?id=152";
const PUBLIC_MOTRIL_AYTO_URL  = "http://www.motril.es";
---

<section id="acknowledgements" class="max-w-7xl mx-auto mt-20 mb-8 px-6">
	<SectionTitle>Agradecimientos</SectionTitle>

	<p class="text-center text-xs uppercase tracking-cofrade text-brand-black/40 dark:text-brand-pearl/40 font-lato mb-12">
		Con la colaboración de
	</p>

	<div class="flex flex-col sm:flex-row justify-center items-center gap-12 sm:gap-0">
		<a
			class="flex flex-col items-center gap-4 px-12 hover:opacity-75 transition-opacity duration-300"
			href={PUBLIC_MOTRIL_CULTURA_URL}
			target="_blank"
		>
			<picture>
				<source srcset="/img/logos/area_cultura_motril.webp" type="image/webp" />
				<img
					src="/img/logos/area_cultura_motril.png"
					alt="Escudo del Área de Cultura del Ayuntamiento de Motril"
					class="h-20 w-auto"
				/>
			</picture>
			<span class="text-center text-xs font-semibold tracking-wide text-brand-black/55 dark:text-brand-pearl/55 max-w-[16ch]">
				Área de Cultura del Ayuntamiento de Motril
			</span>
		</a>

		<!-- Vertical separator -->
		<div class="hidden sm:flex flex-col items-center gap-2 self-stretch justify-center">
			<div class="w-px flex-1 bg-brand-black/10 dark:bg-brand-pearl/10"></div>
			<svg class="text-brand-gold/40 w-2 h-2 flex-shrink-0" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
				<path d="M8 0 L9.5 6.5 L16 8 L9.5 9.5 L8 16 L6.5 9.5 L0 8 L6.5 6.5 Z"/>
			</svg>
			<div class="w-px flex-1 bg-brand-black/10 dark:bg-brand-pearl/10"></div>
		</div>

		<a
			class="flex flex-col items-center gap-4 px-12 hover:opacity-75 transition-opacity duration-300"
			href={PUBLIC_MOTRIL_AYTO_URL}
			target="_blank"
		>
			<picture>
				<source srcset="/img/logos/ayto_motril.webp" type="image/webp" />
				<img
					src="/img/logos/ayto_motril.png"
					alt="Escudo del Excelentísimo Ayuntamiento de Motril"
					class="h-20 w-auto"
				/>
			</picture>
			<span class="text-center text-xs font-semibold tracking-wide text-brand-black/55 dark:text-brand-pearl/55 max-w-[16ch]">
				Excelentísimo Ayuntamiento de Motril
			</span>
		</a>
	</div>
</section>
