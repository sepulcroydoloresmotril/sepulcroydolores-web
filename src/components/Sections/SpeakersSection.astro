---
import SectionTitle from "../SectionTitle.astro";
import Speaker from "../Speaker.astro";
import SPEAKERS from "../../constants/speakers.js"
---

<section id="speakers" class="max-w-7xl mx-auto my-20 px-6">
	<SectionTitle>Ponentes</SectionTitle>
	<p class="max-w-lg mx-auto text-base text-brand-black/55 dark:text-brand-pearl/55 text-center [text-wrap:pretty] font-lato tracking-wide uppercase text-xs mt-0 mb-12">
		Personas relevantes y profesionales en la religiosidad popular, el arte y la historia
	</p>
	<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
		{
			SPEAKERS.map((speaker, id) => (
				<Speaker key={`spk-${id}`} {...speaker} id={id} />
			))
		}
	</div>
</section>
